# ========================================
# NOX_AI - Environment Variables Example
# ========================================

# -------------------
# Stripe Payments
# -------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# -------------------
# Paystack (Recommended for Kenya)
# -------------------
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# -------------------
# Database
# -------------------
DATABASE_URL=sqlite:///payments.db
# For production (PostgreSQL example):
# DATABASE_URL=postgresql://username:password@localhost:5432/nox_ai

# -------------------
# Authentication
# -------------------
SECRET_KEY=super_secret_key_change_this_to_a_long_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -------------------
# AI / LLM Providers
# -------------------
OPENAI_API_KEY=sk-your_openai_key_here
GROQ_API_KEY=gsk_your_groq_key_here
ANTHROPIC_API_KEY=sk-ant_your_anthropic_key_here
XAI_API_KEY=xai-your_xai_key_here

# -------------------
# Other Services
# -------------------
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# -------------------
# Application Settings
# -------------------
ENVIRONMENT=development
DEBUG=True
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000

# -------------------
# Email (Optional)
# -------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here